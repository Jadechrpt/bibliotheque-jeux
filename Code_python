class Le_Pac_Man(pygame.sprite.Sprite):
    # Image de Pac_man + rect
    def __init__(self):
        super().__init__()
        # définition des variables : image, rect, direction...
        self.image = pygame.transform.scale(Pac_man_image_droite, (60, 60))
        self.direction = 1  # Direction (gauche =2, droite 1, haut 3, bas 4)
        self.rect = self.image.get_rect()
        # définition de x et y + position de départ:
        self.initial_x = 50
        self.initial_y = 50
        self.rect.centerx = self.initial_x
        self.rect.centery = self.initial_y
        self.vitesse = 2
        self.force = False
        self.dict_image = {(False, 1): Pac_man_image_droite,
                           (False, 2): Pac_man_image_gauche,
                           (False, 3): Pac_man_image_haut,
                           (False, 4): Pac_man_image_bas,
                           (True, 1): Pac_man_image_droite_vitamine,
                           (True, 2): Pac_man_image_gauche_vitamine,
                           (True, 3): Pac_man_image_haut_vitamine,
                           (True, 4): Pac_man_image_bas_vitamine}
        self.temps_force = 0
        self.temps_vitesse = 0
        # Variable de vie
        self.vie = True
        self.temps_maluce = 0

    def verif_bonus (self): #verifiacation de la durée des bonus + désactivation suivant le type
        if self.force :
            if (Partie_Pacman.temps-Pac_man.temps_force)/Partie_Pacman.frame_seconde > 10:
                self.force = False
        if self.vitesse > 2 :
            if (Partie_Pacman.temps-self.temps_vitesse)/Partie_Pacman.frame_seconde > 10:
                self.vitesse = 2
        if self.vitesse < 2 :
            if Partie_Pacman.temps > self.temps_maluce:
                self.vitesse = 2

    # Mouvement Pac_man
    def déplacement(self):
        keys = pygame.key.get_pressed()
        # Sauvegarde la position initiale avant le déplacement
        self.ancienne_position_x = self.rect.x
        self.ancienne_position_y = self.rect.y

        # Essaye de déplacer Pac_man
        if keys[pygame.K_LEFT] and self.rect.left > 0:
            self.rect.move_ip(-self.vitesse, 0)
            self.direction = 2
            self.verif_col(True)
        if keys[pygame.K_RIGHT] and self.rect.right < Partie_Pacman.largeur:
            self.rect.move_ip(self.vitesse, 0)
            self.direction = 1
            self.verif_col(True)
        if keys[pygame.K_UP] and self.rect.top > 0:
            self.rect.move_ip(0, -self.vitesse)
            self.direction = 3
            self.verif_col(False)
        if keys[pygame.K_DOWN] and self.rect.bottom < Partie_Pacman.hauteur:
            self.rect.move_ip(0, self.vitesse)
            self.direction = 4
            self.verif_col(False)

        #l'image dépend de la direction et s'actualise dans le mouvement
        self.image = pygame.transform.scale(self.dict_image[(self.force, self.direction)], (60, 60))

